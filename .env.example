# Copy to .env via: ./scripts/install.sh
# All paths are host-specific — no defaults are baked into the application code.

DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=9000
DASHBOARD_STATIC_DIR=frontend_dist
DASHBOARD_DATABASE_PATH=data/dashboard.db
DASHBOARD_METRICS_INTERVAL_S=2.0

# General
DASHBOARD_LAN_IP=
DASHBOARD_LLAMACTL_URL=
DASHBOARD_LLAMACTL_KEY=
DASHBOARD_INSTANCE_BIND_HOST=127.0.0.1

# Model library paths (colon-separated)
DASHBOARD_LIBRARY_DIRS=
DASHBOARD_MODEL_DIRS=
DASHBOARD_HF_HOME=
DASHBOARD_HF_HUB_CACHE=
DASHBOARD_LLAMA_CACHE=

# llamactl + llama-server binaries
DASHBOARD_LLAMACTL_CONFIG=
DASHBOARD_RUNTIME_CUDA_TURBOQUANT=
DASHBOARD_RUNTIME_CUDA_STANDARD=
DASHBOARD_RUNTIME_VULKAN=
DASHBOARD_RUNTIME_CPU=
DASHBOARD_RUNTIME_SYCL=
DASHBOARD_RUNTIME_ROCM=
DASHBOARD_INTEL_DEFAULT_SERVER=

# Intel control plane
DASHBOARD_INTEL_CONF=
DASHBOARD_INTEL_ENV_DIR=
DASHBOARD_INTEL_B70_CLI=
DASHBOARD_INTEL_SERVICE_PREFIX=

# Set to 1 after first install
DASHBOARD_INSTALL_COMPLETE=
